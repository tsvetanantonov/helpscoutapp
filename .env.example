# Airtable
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Airtable Table IDs
TABLE_CUSTOMERS=tblXXXXXXXXXXXXXX
TABLE_BOOKINGS=tblXXXXXXXXXXXXXX
