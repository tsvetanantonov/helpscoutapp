TABLE_LEADS=tblXXXXXXXXXXXXXX

# Airtable field names
AIRTABLE_CUSTOMERS_EMAIL_FIELD=Client Email

# Help Scout - found in Manage > Apps > your app > Secret Key
HELPSCOUT_SECRET=your_helpscout_app_secret
